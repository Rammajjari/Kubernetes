apiVersion: v1
kind: ReplicationController
metadata:
  name: webapprc
  namespace: prod
  labels:
    app: webla
spec:
  replicas: 3
  selector:
    app: webla
  template:
    metadata:
      labels:
        app: webla
    spec:
      containers:
        - name: webcon
          image: kkeducationb2/java-webapp:1.1
          ports:
            - containerPort: 8080

---
apiVersion: v1
kind: Service
metadata:
  name: svc-test
  namespace: prod   # ✅ added
spec:
  selector:
    app: webla
  type: NodePort
  ports:
    - port: 80
      targetPort: 8080
      nodePort: 30008   # optional
